{
  "name": "Obico",
  "version": "1.0.0",
  "slug": "obico",
  "description": "Steuere und überwache deine 3D-Drucker mit Obico.",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "stdin": true,
  "host_network": true,
  "map": ["config:rw", "ssl:ro"],
  "options": {
    "username": "",
    "password": ""
  },
  "schema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "title": "Obico Benutzername "
      },
      "password": {
        "type": "string",
        "title": "Obico Passwort"
      }
    }
  }
}
